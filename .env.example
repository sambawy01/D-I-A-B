# Public site URL (used for auth email redirects)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Supabase — DEDICATED DIAB project (project settings → API). Use the anon key,
# never service_role, in the NEXT_PUBLIC_ vars.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_DIAB_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Postgres connection for Drizzle (migrations + trusted server queries).
# Supabase "Connection pooling" (transaction) string; prepare:false is set in code.
DATABASE_URL="postgresql://postgres.YOUR_DIAB_PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres"

# Hermes copilot runs on Ollama Cloud (reused from the Hermes Gateway on Railway).
# OpenAI-compatible endpoint — base URL ends in /v1.
OLLAMA_BASE_URL="https://ollama.com/v1"
OLLAMA_API_KEY="..."
HERMES_MODEL="glm-5.2"   # verified tool-capable via /chat/completions

# Reused account-level keys from the Hermes Gateway (added when wiring those features)
# MCP_COMPOSIO_API_KEY=""   # feature 2: Gmail auto-import
# RESEND_API_KEY=""         # email nudges
