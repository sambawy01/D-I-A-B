# Supabase — project settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Postgres connection for Drizzle (migrations + trusted server queries).
# Use the Supabase "Connection pooling" (transaction) string; prepare:false is set in code.
DATABASE_URL="postgresql://postgres.YOUR_PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres"

# Claude API (Hermes) — server only
ANTHROPIC_API_KEY="sk-ant-..."

# Composio (Gmail auto-import) — added when wiring feature 2
# COMPOSIO_API_KEY=""
